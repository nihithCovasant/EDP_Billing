// EDP Billing — PostgreSQL (dbdiagram.io compatible)
// Paste at https://dbdiagram.io → Import

Project edp_billing {
  database_type: 'PostgreSQL'
  Note: 'EDP billing agent. 3 tables, all prefixed edpb_. Soft refs only — no FK constraints.'
}

Enum segment_status {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  FAILED
}

Enum segment_state {
  INIT
  WAITING_FOR_FILE_UPLOAD
  TRIGGERED
  WAITING_FOR_BILLPOSTING
  WAITING_FOR_RECON
  WAITING_FOR_CONTRACT_NOTE_GENERATION
  WAITING_FOR_GTG
  WAITING_FOR_COMPLETION
}
// INIT..WAITING_FOR_CONTRACT_NOTE_GENERATION: 10-segment pipeline (EQ,DR,CUR,SLB,NCDEX,NCDEXPHY,MCX,MCXPHY,NSECOM,MF); TRIGGERED shared with post-trade
// WAITING_FOR_GTG..WAITING_FOR_COMPLETION: 5 post-trade process pipeline (COLVAL,COLALLOC,MTFFT,DMRPT,DMSTMT)
// No states here for terminal outcomes — those live on segment_status. current_state is set to NULL once COMPLETED/SKIPPED, or left frozen where it broke for FAILED.

Enum agent_control_action {
  START
  STOP
}

Table edpb_properties {
  id varchar(36) [pk, note: 'UUID']
  trade_date date [not null, note: 'Trading calendar date']
  workflow_json json [not null, note: 'segments: segment_code, login_id, window_start, window_end (same-day; window_end only rolls onto the next day if it is at/before window_start, e.g. 17:00->06:00 — derived, not a field). Always IST — no per-config timezone field.']
  is_active boolean [not null, default: true, note: 'One active row per trade_date']
  uploaded_by varchar(256) [not null, default: 'system']
  uploaded_at timestamp [not null, default: `now()`]
  superseded_at timestamp [note: 'Set when newer config replaces this row']
  created_at timestamp [not null, default: `now()`]
  indexes {
    (trade_date) [unique, name: 'ix_edpb_properties_one_active_per_date', note: 'Partial: WHERE is_active — DB-enforced, closes the concurrent-upload race in repository.workflow.upload()']
  }
  Note: 'Daily workflow config. Every upload creates a new row unconditionally (no content-hash dedup) — sequence_order and segment_name are code constants, not stored.'
}

Table edpb_segment_execution {
  id varchar(36) [pk, note: 'UUID']
  trade_date date [not null]
  segment_code varchar(32) [not null, note: 'Real segment: EQ DR CUR SLB NCDEX NCDEXPHY MCX MCXPHY NSECOM MF | Post-trade: COLVAL COLALLOC MTFFT DMRPT DMSTMT']
  config_id_used varchar(36) [note: 'Soft ref to edpb_properties.id (real segments only)']
  status segment_status [not null, default: 'PENDING']
  current_process varchar(64) [note: 'CBOS ProcessName e.g. BILLPOSTING or CollateralValuation']
  current_state segment_state [note: 'Active state — see segment_state enum note']
  process_id varchar(64) [note: 'From getNewTradeProcess PROCESSID=0 (real segments only)']
  process_id_reserved_at timestamp
  processes_json json [not null, note: 'Real segments: holiday_check file_upload_ready trigger bill_posting recon contract_note | Post-trade: gtg trigger confirm | Real-segment "trigger" substate is PID_RESERVED -> TRIGGERING -> TRIGGERED/FAILED; TRIGGERING is committed (session.commit, not just flush) BEFORE the CBOS trigger call so a crash can never lose it (double-trigger crash protection, see state_machine.RealSegmentStateMachine.handle_triggered / _recover_trigger). Post-trade "trigger" substate is the same TRIGGERING marker + commit before the call; the WAITING_FOR_GTG "already triggered" CBOS check (state_machine.PostTradeStateMachine.handle_waiting_for_gtg) rules out most double-trigger risk before TRIGGERED is even entered, but a resume that still finds TRIGGERING set refuses to re-fire and marks the process FAILED for manual verification instead (handle_triggered).']
  started_at timestamp [note: 'PENDING to IN_PROGRESS']
  completed_at timestamp [note: 'COMPLETED FAILED or SKIPPED']
  last_heartbeat_at timestamp [note: 'Updated each cycle while IN_PROGRESS']
  skip_category varchar(32) [note: 'SKIPPED: CBOS_SKIP MANUAL_SKIP | FAILED: CBOS_ERROR SYSTEM_ERROR (unmapped state) TIMEOUT (window deadline exceeded)']
  skip_reason text
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  indexes {
    (trade_date, segment_code) [unique, name: 'uq_segment_execution_per_day']
    trade_date
  }
  Note: 'Up to 12 rows per day (7 real segments + 5 T+1 post-trade processes). segment_name sequence_order runtime_health window times are computed at read time not stored.'
}

Table edpb_agent_control {
  id varchar(36) [pk, note: 'UUID']
  action agent_control_action [not null]
  requested_at timestamp [not null, default: `now()`]
  requested_by varchar(256) [not null, default: 'system']
  reason text
  effective_state varchar(32) [not null, note: 'RUNNING or STOPPED']
  snapshot_json json [note: 'Day summary snapshot at STOP time']
  Note: 'Append-only START STOP audit log. Never updated.'
}

Ref: edpb_segment_execution.config_id_used > edpb_properties.id

TableGroup config {
  edpb_properties
}

TableGroup runtime {
  edpb_segment_execution
}

TableGroup ops {
  edpb_agent_control
}
