// EDP Billing — PostgreSQL (dbdiagram.io compatible)
// Paste at https://dbdiagram.io → Import

Project edp_billing {
  database_type: 'PostgreSQL'
  Note: 'EDP billing agent. 3 tables. Soft refs only — no FK constraints.'
}

Enum segment_status {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  FAILED
}

Enum segment_phase {
  HOLIDAY_CHECK
  RESERVE_PID
  AWAIT_FILE_UPLOAD
  TRIGGER
  AWAIT_BILLPOSTING
  AWAIT_RECON
  AWAIT_CONTRACT_NOTE
  COLLATERAL_VALUATION
  COLLATERAL_ALLOCATION
  FUND_TRANSFER
  MTF_BUY
  MTF_SELL
  WEEKLY_AUTO_CLOSURE
  DONE
}

Enum agent_control_action {
  START
  STOP
}

Table edp_properties {
  id varchar(36) [pk, note: 'UUID']
  trade_date date [not null, note: 'Trading calendar date']
  workflow_json json [not null, note: 'segments: segment_code, login_id, window_start, window_end, window_end_next_day']
  content_hash varchar(64) [not null, note: 'SHA-256 of workflow_json']
  is_active boolean [not null, default: true, note: 'One active row per trade_date']
  uploaded_by varchar(256) [not null, default: 'system']
  uploaded_at timestamp [not null, default: `now()`]
  superseded_at timestamp [note: 'Set when newer config replaces this row']
  created_at timestamp [not null, default: `now()`]
  Note: 'Daily workflow config. sequence_order and segment_name are code constants, not stored.'
}

Table segment_execution {
  id varchar(36) [pk, note: 'UUID']
  trade_date date [not null]
  segment_code varchar(32) [not null, note: 'EQ DR CUR SL NCDEX MCX NSECOM MF MTFOPS']
  config_id_used varchar(36) [note: 'Soft ref to edp_properties.id']
  config_hash_used varchar(64) [note: 'content_hash at seed time']
  status segment_status [not null, default: 'PENDING']
  current_process varchar(64) [note: 'CBOS ProcessName e.g. BILLPOSTING']
  current_phase segment_phase [note: 'Active pipeline stage']
  process_id varchar(64) [note: 'From getNewTradeProcess PROCESSID=0']
  process_id_reserved_at timestamp
  lock_json json [not null, note: 'state owner acquired_at expires_at']
  processes_json json [not null, note: 'holiday_check file_upload_ready trigger bill_posting recon contract_note']
  started_at timestamp [note: 'PENDING to IN_PROGRESS']
  completed_at timestamp [note: 'COMPLETED FAILED or SKIPPED']
  last_heartbeat_at timestamp [note: 'Updated each cycle while IN_PROGRESS']
  skip_category varchar(32) [note: 'CBOS_SKIP TIMEOUT MANUAL_SKIP AGENT_RESTART CBOS_ERROR']
  skip_reason text
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  indexes {
    (trade_date, segment_code) [unique, name: 'uq_segment_execution_per_day']
    trade_date
  }
  Note: 'Up to 9 rows per day. segment_name sequence_order runtime_health window times are computed at read time not stored.'
}

Table agent_control {
  id varchar(36) [pk, note: 'UUID']
  action agent_control_action [not null]
  requested_at timestamp [not null, default: `now()`]
  requested_by varchar(256) [not null, default: 'system']
  reason text
  effective_state varchar(32) [not null, note: 'RUNNING or STOPPED']
  snapshot_json json [note: 'Day summary snapshot at STOP time']
  Note: 'Append-only START STOP audit log. Never updated.'
}

Ref: segment_execution.config_id_used > edp_properties.id

TableGroup config {
  edp_properties
}

TableGroup runtime {
  segment_execution
}

TableGroup ops {
  agent_control
}
