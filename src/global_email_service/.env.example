# global_email_service SMTP configuration template.
# Copy this file to ".env" in this same folder and fill in real values.
# (This module's .env is loaded independently of the repo-root .env — see
# config.py — so this folder is fully self-contained/portable.)

# --- SMTP connection ---
EMAIL_SMTP_HOST=smtp.yourcompany.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=alerts@yourcompany.com
EMAIL_SMTP_PASSWORD=changeme
EMAIL_SMTP_USE_TLS=true
EMAIL_SMTP_USE_SSL=false
EMAIL_SMTP_TIMEOUT_SECONDS=15

# --- Sender identity ---
EMAIL_FROM_ADDRESS=alerts@yourcompany.com
EMAIL_FROM_NAME=EDP Billing Alerts

# --- Default recipients (comma-separated) ---
EMAIL_DEFAULT_TO=mofsl-ops@example.com
EMAIL_DEFAULT_CC=

# --- Retry behaviour ---
EMAIL_MAX_RETRIES=2
EMAIL_RETRY_BACKOFF_SECONDS=2

# --- Set to false once real SMTP_HOST/credentials above are filled in ---
EMAIL_DRY_RUN=true
