# global_email_service configuration template.
# Copy this file to ".env" in this same folder and fill in real values.
# (This module's .env is loaded independently of the repo-root .env — see
# config.py — so this folder is fully self-contained/portable.)

# --- Microsoft Graph (OAuth2 client-credentials + sendMail) ---
# Azure AD app registration must have application permission Mail.Send
# (admin-consented), and the sender mailbox must exist in that tenant.
#
# Each of these three also accepts a "_FILE" variant instead (e.g.
# EMAIL_GRAPH_CLIENT_SECRET_FILE=/run/secrets/graph-client-secret) for
# platforms that mount secrets as files rather than plaintext env vars.
EMAIL_GRAPH_TENANT_ID=
EMAIL_GRAPH_CLIENT_ID=
EMAIL_GRAPH_CLIENT_SECRET=
EMAIL_GRAPH_SENDER=rms@covasant.com
EMAIL_GRAPH_TIMEOUT_SECONDS=15

# --- Sender display name (used in email metadata/logs only) ---
EMAIL_FROM_NAME=EDP Billing Alerts

# --- Default recipients (comma-separated) ---
EMAIL_DEFAULT_TO=mofsl-ops@example.com
EMAIL_DEFAULT_CC=

# --- Retry behaviour ---
EMAIL_MAX_RETRIES=2
EMAIL_RETRY_BACKOFF_SECONDS=2

# --- Set to false once real Graph credentials above are filled in ---
EMAIL_DRY_RUN=true

# --- Standalone server (see main.py) — CAMS-style names, defaults shown ---
HOST=0.0.0.0
PORT=9200
LOG_LEVEL=INFO
