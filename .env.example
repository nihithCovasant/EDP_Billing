# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================
# This .env file is ONLY for API keys that come from your secret manager.
# All other configuration (Langfuse, Sentry, Database, LiteLLM, etc.) is in:
#   src/config/agent_config.json → secrets section
#
# Deployment approach:
# 1. Mount agent_config.json with your secrets filled in
# 2. Set API keys as environment variables (from secret manager)
# 3. Run the container
#
# Example:
#   docker run -d \
#     -v /path/to/agent_config.json:/app/config/agent_config.json \
#     -e OPENAI_API_KEY="${SECRET_MANAGER_OPENAI_KEY}" \
#     -e ANTHROPIC_API_KEY="${SECRET_MANAGER_ANTHROPIC_KEY}" \
#     your-agent:latest
# ============================================================================

# ============================================================================
# LLM API Keys - These come from your deployment secret manager
# ============================================================================
# OpenAI (GPT-4, GPT-4o, GPT-3.5-turbo, etc.)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (Claude 3 Opus, Sonnet, Haiku)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google (Gemini Pro, Gemini 1.5 Pro, etc.)
GOOGLE_API_KEY=your-google-api-key-here




# ============================================================================
# Basic Server Configuration (Optional - can override defaults)
# ============================================================================
AGENT_NAME=My Custom Agent
AGENT_DESCRIPTION=A customizable AI agent built with LangGraph
HOST=0.0.0.0
PORT=8005
LOG_LEVEL=INFO
STREAMING_ENABLED=true



# ============================================================================
# OTEL Configuration
# ============================================================================
OTEL_ENABLED=true
OTEL_CONSOLE_LOGGING=true
OTEL_LOGGING_ENABLED=true
OTEL_TRACING_ENABLED=true
OTEL_CONSOLE_TRACING=true

# Set a fixed UUID per deployment so OTEL re-init is a no-op (prevents double-init crash)
OTEL_CONFIG_UUID=<set-a-fixed-value-per-deployment>
# agent_id is read from agent_config.json → agent_instance_id (not from env)

# ============================================================================
# EDP Agent — Wake loop
# ============================================================================
# Seconds between wake cycles (default 60 if unset).
# EDP_WAKE_INTERVAL_SECONDS=60

# ============================================================================
# EDP Agent — CBOS Connection (single place to switch mock <-> real CBOS)
# ============================================================================
# These override agent_config.json → default.edp.cbos_* when set.
# Leave unset to use the values from agent_config.json instead.
#
# Option A — Test against the local Mock CBOS Server (see mock_cbos/README.md):
#   1. Run:  python -m mock_cbos.main   (defaults to http://localhost:9100)
#   2. Uncomment the 3 lines below.
#
# Option B — Test against the real CBOS system (VDI/VPN required):
#   Set CBOS_STATUS_URL / CBOS_PROCESS_URL to the real base URLs and
#   CBOS_USE_MOCK=false. No code changes needed either way.
#
# CBOS_STATUS_URL=http://localhost:9100
# CBOS_PROCESS_URL=http://localhost:9100
# CBOS_USE_MOCK=false
# CBOS_LOGIN_ID=CV0001

# ============================================================================
# Chat agent — "download file" tool (src/tools/edpb_download.py)
# ============================================================================
# Separate from the EDP billing wake loop above — this is a simple chat tool:
# user says "download file with filename X" and it POSTs a payload to the
# EDPB portal API. Config (api_url/member_code/username/password) lives in
# src/config/agent_config.json -> agent_config.secrets.edpb_download — edit
# it there. The EDPB_* vars below are optional local overrides only (they
# win over the config file if set).
# EDPB_DOWNLOAD_API_URL=https://real-edpb-host/api/edpb/download
# EDPB_MEMBER_CODE=<member-code>
# EDPB_USERNAME=<username>
# EDPB_PASSWORD=<password>

# Option C — PostgreSQL for EDP agent state (required — no local-file fallback)
# Either set individual fields:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=EDP_Billing
# DB_USERNAME=postgres
# DB_PASSWORD=your-password-here
# Or a full async URL:
# DATABASE_URL=postgresql+asyncpg://postgres:your-password-here@localhost:5432/EDP_Billing
#
# Schema migrations (Alembic — see alembic/README):
#   .venv\Scripts\python.exe -m alembic upgrade head
# If upgrading from pre-Alembic DB (tables already exist via create_all):
#   .venv\Scripts\python.exe -m alembic stamp head

# ============================================================================
# EDP Agent — Terminal-status email alerts (global_email_service)
# ============================================================================
# Fired on every segment/post-trade process reaching COMPLETED, SKIPPED, or
# FAILED (see src/agent/edp/repository/segment.py::move_to_state()). Defaults
# to dry-run (logs the rendered email instead of calling Graph) so the agent
# runs with zero mail setup; set the EMAIL_GRAPH_* values and flip
# EMAIL_DRY_RUN=false to actually send. Full details: global_email_service/README.md
#
# All EMAIL_* vars live HERE, not in global_email_service/.env — that file
# is only loaded when running the email service standalone (its own
# load_dotenv() only searches upward from cwd, and the agent's cwd is this
# repo root, not that subdirectory), so anything set only there is inert
# when running the agent.
EMAIL_DRY_RUN=true
# EMAIL_GRAPH_TENANT_ID=<azure-ad-tenant-id>
# EMAIL_GRAPH_CLIENT_ID=<app-registration-client-id>
# EMAIL_GRAPH_CLIENT_SECRET=<app-registration-client-secret>
# EMAIL_GRAPH_SENDER=rms@covasant.com
# EMAIL_GRAPH_TIMEOUT_SECONDS=15
# EMAIL_FROM_NAME=EDP Billing Alerts
# EMAIL_DEFAULT_TO=mofsl-ops@example.com
# EMAIL_DEFAULT_CC=mofsl-ops-cc@example.com
# EMAIL_MAX_RETRIES=2
# EMAIL_RETRY_BACKOFF_SECONDS=2

# ============================================================================
# ALL OTHER CONFIGURATION IS IN agent_config.json → secrets SECTION
# ============================================================================
# The following are now configured in agent_config.json under "secrets":
# - Langfuse (public_key, secret_key, host)
# - Sentry (dsn, environment, traces_sample_rate)
# - Database (postgres connection_string)
# - LiteLLM (base_url, enabled)
# - GCP (project_id, location, use_workload_identity)
# - Pinecone (environment)
# - Remote Config (registry_base_url, deployment_plan_id, etc.)
#
# See src/config/agent_config.json for the full secrets structure.
# ============================================================================
